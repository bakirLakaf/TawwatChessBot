# ================== إعدادات بوت Tawwat Chess ==================
# انسخ هذا الملف إلى ملف اسمه .env واملأ القيم. لا تشارك .env مع أحد أبدًا.

# --- تيليجرام ---
# 1) أنشئ بوتًا عبر @BotFather وخذ التوكن (إن تسرّب، استعمل /revoke لتوليد جديد)
TELEGRAM_BOT_TOKEN=ضع_توكن_البوت_هنا
# 2) أرسل رسالة لـ @userinfobot ليعطيك رقمك (chat id)
TELEGRAM_ADMIN_CHAT_ID=ضع_رقمك_هنا

# ============================================================
# مزوّد إعادة الصياغة (لازم للأخبار فقط). اختر طريقة واحدة:
# ============================================================

# ===== الطريقة (أ): مزوّد مجاني متوافق مع OpenAI (مستحسن) =====
# إن ملأت LLM_API_BASE فسيُستعمل هذا المزوّد (وتُتجاهل مفاتيح Claude).
#
# • Gemini المجاني (الأكثر موثوقية، مفتاح مجاني من aistudio.google.com):
#     LLM_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai/
#     LLM_MODEL=gemini-2.5-flash
#
# • bynara / NaraRouter (مفتاح مجاني من router.bynara.id → Create key):
#     LLM_API_BASE=https://router.bynara.id/v1
#     LLM_MODEL=mistral-medium-3-5
#     LLM_FALLBACK_MODELS=mistral-large   # احتياط يُجرَّب إذا فشل الأساسي (اختياري)
#
LLM_API_BASE=
LLM_API_KEY=
LLM_MODEL=

# ===== الطريقة (ب): Claude مباشرة (مدفوع — حد أدنى 5$) =====
# يُستعمل فقط إذا تركت LLM_API_BASE فارغًا.
ANTHROPIC_API_KEY=
# الافتراضي رخيص. للجودة الأعلى: claude-sonnet-4-6
CLAUDE_MODEL=claude-haiku-4-5-20251001

# --- فيسبوك (Graph API) ---
FB_PAGE_ID=ضع_معرّف_الصفحة_هنا
FB_PAGE_ACCESS_TOKEN=ضع_توكن_الصفحة_طويل_الأمد_هنا

# --- سلوك البوت ---
NEWS_CHECK_MINUTES=20        # فحص الأخبار كل كم دقيقة (15–20 مستحسن)
MAX_POSTS_PER_CHECK=3        # أقصى عدد منشورات في الفحص الواحد
AUTO_PUBLISH=false          # false = موافقتك مطلوبة قبل نشر الأخبار (مستحسن)
NEWS_MAX_AGE_HOURS=24       # تجاهل أي خبر أقدم من هذه المدة (تفادي الأخبار القديمة)

# --- المحتوى المجدول (ألغاز/حكم/نقلات/بطولة) ---
# false = يصلك للموافقة في وقته (آمن للتجربة). true = نشر تلقائي هادئ في وقته.
SCHEDULED_AUTO_PUBLISH=false
# المنطقة الزمنية للجدولة
TIMEZONE=Africa/Algiers

# --- نافذة النشر التلقائي (بتوقيت الجزائر) ---
# النشر التلقائي يحدث فقط بين هاتين الساعتين؛ الأخبار العاجلة تُنشَر فورًا.
POST_WINDOW_START=8          # 8 صباحًا
POST_WINDOW_END=22          # 10 مساءً

# --- تشغيل ---
# PORT يحدّده Railway تلقائيًا. على ويندوز اتركه 8080.
PORT=8080
